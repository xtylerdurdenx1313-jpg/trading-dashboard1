# Raydium Degen Trading Agent — Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Bot polling interval (seconds)
TELEGRAM_POLL_INTERVAL=60


# ==========================================
# SOLANA RPC CONFIGURATION
# ==========================================
# Free public RPC endpoint (may have rate limits)
# SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# OR use a faster paid RPC (Quicknode, Helius, etc.)
# SOLANA_RPC_ENDPOINT=https://your-rpc-endpoint.com
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com


# ==========================================
# GMGN.AI CONFIGURATION
# ==========================================
# If GMGN provides API access, add key here
# GMGN_API_KEY=your_gmgn_api_key_here
GMGN_POLL_INTERVAL=30


# ==========================================
# DUNE ANALYTICS CONFIGURATION
# ==========================================
# Dune API key for dashboard queries
# Get from dune.com/settings/api
# DUNE_API_KEY=your_dune_api_key_here
DUNE_POLL_INTERVAL=300


# ==========================================
# WHALE WALLET ADDRESSES
# ==========================================
# Conservative whale (50x flips, low drawdown)
WHALE_WALLET_1=4Be9CvxqHW6BYiRAxW9Q3xu1ycTMWaL5z8NX4HR3ha7t

# Aggressive whale (high volume, 5-20x targets)
WHALE_WALLET_2=H72yLkhTnoBfhBTXXaj1RBXuirm8s8G5fcVh2XpQLggM

# Whale wallet polling interval (seconds)
WHALE_POLL_INTERVAL=20


# ==========================================
# PAPER TRADING CONFIGURATION
# ==========================================
# Set to 'true' for paper trading, 'false' for live trading
PAPER_TRADING=true

# Starting capital for paper trading
PAPER_TRADING_CAPITAL=500.00

# Flag to enable/disable live mode
# LIVE_TRADING=false


# ==========================================
# RAYDIUM CONFIGURATION
# ==========================================
# Raydium Program ID (Solana)
RAYDIUM_PROGRAM_ID=675kPX9MHTjS2zt1qLCcV-XYGoVNYmJAstmLaWwc2xQ

# Raydium API endpoint (optional)
# RAYDIUM_API_ENDPOINT=https://api.raydium.io/v2


# ==========================================
# PUMP.FUN CONFIGURATION
# ==========================================
# Pump.fun uses Raydium under the hood
# No separate API key needed, uses Solana RPC


# ==========================================
# TRADING CONFIGURATION
# ==========================================
# Active trading hours (24-hour format, EST)
ACTIVE_HOURS_START=09:00
ACTIVE_HOURS_END=20:00

# Spawn cycle interval (minutes)
SPAWN_INTERVAL=5

# Timezone
TIMEZONE=America/New_York


# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log to file and stdout
LOG_TO_FILE=true
LOG_DIR=logs


# ==========================================
# STRATEGY PARAMETERS
# ==========================================
# Max trade size (USD)
MAX_TRADE_SIZE=100.0

# Min trade size (USD)
MIN_TRADE_SIZE=25.0

# Daily loss limit (USD)
DAILY_LOSS_LIMIT=25.0

# Account floor (minimum equity before pausing)
ACCOUNT_FLOOR=450.0

# Hard stop loss percentage
HARD_STOP_LOSS_PCT=-20.0

# Position timeout (hours)
TRADE_TIMEOUT_HOURS=4


# ==========================================
# NOTIFICATIONS (Optional)
# ==========================================
# Discord webhook for alerts (optional)
# DISCORD_WEBHOOK_URL=your_webhook_url_here

# Email for alerts (optional)
# ALERT_EMAIL=your_email@example.com

# Enable/disable daily summary
DAILY_SUMMARY=true


# ==========================================
# DEBUG & DEVELOPMENT
# ==========================================
# Enable debug logging (verbose output)
DEBUG=false

# Dry-run mode (evaluate signals, don't execute trades)
DRY_RUN=false

# Delay execution for testing (seconds)
EXECUTION_DELAY=0
